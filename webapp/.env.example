# ── Database (Neon) ──────────────────────────────────────────────────────────
# Get from https://console.neon.tech → Connection Details → Connection string
DATABASE_URL="postgresql://user:password@ep-xxxx.us-east-2.aws.neon.tech/neondb?sslmode=require"

# ── Auth ─────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters — generates encrypted session cookies
# Generate: openssl rand -base64 32
NUXT_SESSION_PASSWORD="change-me-generate-with-openssl-rand-base64-32"

# ── Cloudflare R2 (document uploads) ────────────────────────────────────────
# Create bucket at https://dash.cloudflare.com → R2 → Create Bucket
# Create API token at R2 → Manage API Tokens → Create API Token (Object Read & Write)
R2_ACCOUNT_ID="your-cloudflare-account-id"
R2_ACCESS_KEY_ID="your-r2-access-key-id"
R2_SECRET_ACCESS_KEY="your-r2-secret-access-key"
R2_BUCKET_NAME="rex-documents"
# Public URL for the bucket (set up custom domain or use r2.dev preview URL)
R2_PUBLIC_URL="https://pub-xxxx.r2.dev"
# Custom domain connected to the R2 bucket in Cloudflare (required for browser
# uploads via presigned URLs — the CORS policy only fires on the custom domain,
# not on the raw *.r2.cloudflarestorage.com S3 endpoint).
# In Cloudflare: R2 → bucket → Settings → Custom Domains → Connect Domain
# Example: R2_UPLOAD_URL="https://uploads.r-recs.com"
R2_UPLOAD_URL=""

# ── Axiom logging ────────────────────────────────────────
AXIOM_TOKEN="your-axiom-token"
AXIOM_DATASET="your-axiom-dataset-name"

# ── Gemini ───────────────────────────────────────────────
GEMINI_API_KEY="your-gemini-key"
GEMINI_MODEL="gemini-2.5-flash-lite"

# ── Public data sources ──────────────────────────────────────────────────────
# Override to point at CDN-hosted JSON if preferred; defaults to /public/*.json
NUXT_PUBLIC_COMPANIES_URL="/companies.json"
NUXT_PUBLIC_CONTRACTS_URL="/contracts.json"
NUXT_PUBLIC_POLYGONSCAN_BASE="https://polygonscan.com"

# ── Wallets ──────────────────────────────────────────────────────────────────
# The designated receive-only return wallet for REC → carbon credit conversion
RETURN_WALLET="0x6e61b86d97ebe007e09770e6c76271645201fd07"
RETIREMENT_WALLET="0x51475BEdAe21624c5AD8F750cDBDc4c15Ca8F93f"

# ── Seed scripts ─────────────────────────────────────────────────────────────
# Used only by `npm run seed:admin` to create the first admin account
ADMIN_USERNAME="admin"
ADMIN_EMAIL="admin@yourorg.com"
ADMIN_PASSWORD="change-me-at-least-12-chars"
# Optional: link the admin user to a company wallet (lowercase)
ADMIN_COMPANY_WALLET=""

# Used only by `npm run seed:test-user` and Playwright E2E tests.
# This user is a generator + buyer (not admin) and exists solely for testing.
# Must be created before running E2E tests: npm run seed:test-user
TEST_USER_USERNAME="playwright-test"
TEST_USER_EMAIL="playwright-test@example.com"
